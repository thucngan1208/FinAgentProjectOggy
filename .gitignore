# ============================================================
#  FinAgent — .gitignore
#  Add this file to the ROOT of your project.
#  Git will never track anything listed here.
# ============================================================

# ── SECRET: API keys & environment variables ─────────────────
# NEVER commit the real .env — it contains your API keys.
# Share .env.example (included in the repo) instead.
.env
.env.local
.env.*.local

# ── Python cache & build artefacts ───────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────
venv/
.venv/
env/
.env/          # also catches venv named ".env"
ENV/

# ── Data files (often large / sensitive) ─────────────────────
# Raw downloaded data — regenerated by running module1
data/raw/
# Cleaned data — regenerated by module2
data/clean/
# Generated charts — regenerated by module3
data/charts/
# Generated reports — regenerated by module4
data/reports/
# Log files
data/*.log
*.log

# ── Jupyter Notebooks checkpoints ────────────────────────────
.ipynb_checkpoints/

# ── OS metadata ───────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / editor settings ─────────────────────────────────────
.vscode/settings.json    # keep .vscode/extensions.json if you want to share recommended extensions
.idea/
*.swp
*.swo

# ── pytest / coverage ─────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
