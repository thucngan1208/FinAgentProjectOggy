# FinAgent — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit the real .env to Git.

# Google AI Studio (Gemini) — Required for Module 4
# Get free key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_ai_studio_key_here

# NewsAPI — Optional (for news/sentiment collection)
# Get free key at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Alpha Vantage — Optional (for FX rates)
# Get free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here
